{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/src/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/dist/$1",
            "check": true
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/dist/index.html"
        }
    ],
    "functions": {
        "backend/src/server.js": {
            "runtime": "nodejs20.x",
            "maxDuration": 10
        }
    },
    "cleanUrls": true
}