{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/src/server.js"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "/backend/uploads/$1"
        },
        {
            "source": "/(assets/.*)",
            "destination": "/frontend/dist/$1"
        },
        {
            "source": "/([^/]+\\.[a-z0-9]+)$",
            "destination": "/frontend/dist/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/frontend/dist/index.html"
        }
    ],
    "cleanUrls": true
}